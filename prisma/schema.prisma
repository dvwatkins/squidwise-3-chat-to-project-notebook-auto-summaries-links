generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notebook {
  id          Int      @id @default(autoincrement())
  title       String
  summary     String
  decisions   String[]
  todos       String[]
  codeSnippets String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        Tag[]    @relation("NotebookTags")
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  notebooks Notebook[] @relation("NotebookTags")
}