generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Chat {
  id          String   @id @default(cuid())
  title       String
  messages    Json
  summary     String?
  decisions   String[]
  todos       String[]
  codeSnippets String[]
  fileLinks   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}